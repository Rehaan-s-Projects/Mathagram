rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: any authenticated user can read (for leaderboard), only owner can write
    // Admin can set 'banned' and 'banReason' fields on any user
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && !('banned' in request.resource.data && request.resource.data.banned == true
             && request.auth.uid == userId);

      // Course-level progress
      match /progress/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Lesson-level data within a course
        match /lessons/{lessonId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Violation reports: authenticated users can create (write-only, no read)
    match /violations/{violationId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    // Post reports: authenticated users can create (write-only, no read)
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    // Learning Posts: anyone can read, authenticated users can create, only owner can update
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 500
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.under13 != true;
      allow update: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
